# Copy this file to `.env` and fill in real local values.
# `.env` is gitignored and must NEVER be committed.
# In production these come from AWS Secrets Manager / Parameter Store, not from any file.

# --- Local Postgres (docker-compose) ---
POSTGRES_USER=scribe
POSTGRES_PASSWORD=change_me_local_only
POSTGRES_DB=clinical_scribe

# --- Backend database connection ---
# Async SQLAlchemy URL. Host is localhost because Postgres is published on 5432 by docker-compose.
DATABASE_URL=postgresql+asyncpg://scribe:change_me_local_only@localhost:5432/clinical_scribe

# --- Auth (filled in when we build the auth layer) ---
JWT_SECRET=generate_a_long_random_string_here
JWT_ACCESS_TTL_MINUTES=20

# --- Anthropic (filled in when we build generation) ---
ANTHROPIC_API_KEY=
